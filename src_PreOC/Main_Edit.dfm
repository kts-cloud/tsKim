          Font.Style = []
          HiddenCaret = False
          ImeName = 'Microsoft IME 2010'
          Lines.Strings = (
            'Func_call::TxIcInit()'
            '{'
            '    mipiic.write 0x31 0x89 0x00'
            '    mipiic.read 0x3A 0x02'
            '    mipiic.read 0x3B 0x02'
            '    mipiic.write 0x5B,0x00,0x00'
            '    mipiic.write 0x40,0xC1,0x00'
            '}_end_func'
            ''
            '// .mion'
            'Func_call::ModuleOn()                          '
            '{'
            '    mipi.write 0x39 0x2A 0x00 0x00 0x05 0x9F'
            '    mipi.write 0x39 0x2B 0x00 0x00 0x06 0xA7'
            '    mipi.write 0x15 0x35 0x00'
            '    delay.ms 10'
            '    mipi.write 0x05 0x11'
            '    delay.ms 100'
            ''
            '}_end_func'
            ''
            '// .mioff'
            'Func_call::ModuleOff()'
            '{'
            '    mipi.write 0x05 0x28'
            '    mipiic.write 0x3D 0X00 0X00'
            '    delay.ms 5'
            '    mipi.write 0x05 0x34'
            '    mipi.write 0x05 10'
            '    mipiic.write 0x3D 0X00 0X00'
            '    delay.ms 100'
            '    mipiic.write 0x12 0x01 0x01'
            '    delay.ms 10'
            '    mipiic.write 0x12 0x00 0x00'
            ''
            '}_end_func'
            ''
            'Func_call::PwrOn()'
            '{'
            '    mdm.reset 0'
            '    delay.ms 10'
            '    mdm.reset 1'
            '    delay.ms 10'
            '    lcm.reset 0'
            '    delay.ms 5'
            '    vbat.on'
            '    delay.ms 1'
            '    vcc.on'
            '    delay.ms 1'
            '    vext.on'
            '    delay.ms 10'
            '    vlcd.on'
            '    delay.ms 10'
            '    mipiic.write 0x12 0x01 0x01'
            '    delay.ms 10'
            '    mipiic.write 0x12 0x00 0x00'
            '    delay.ms 10'
            '    lcm.reset 1'
            '    delay.ms 5'
            '    lcm.reset 0'
            '    delay.ms 5'
            '    lcm.reset 1'
            '    delay.ms 10'
            '    mdm.init'
            ''
            '    mipiic.write 0x3D 0x01 0x00'
            ''
            ''
            '}_end_func'
            ''
            ''
            ''
            'Func_call::PwrOff()'
            '{'
            ''
            '    delay.ms 5'
            ''
            '    mdm.reset 0'
            '    delay.ms 10'
            ''
            '    delay.ms 15'
            ''
            '    delay.ms 15'
            ''
            '    lcm.reset 0'
            ''
            ''
            '}_end_func                                    '
            ''
            '// *.misc  Screen Code.'
            'Func_call::ScreenCode()'
            '{                 '
            '    mipiic.write 0x3D 0x01 0x00           // Video Enable'
            ''
            '    vpp.off                      '
            ''
            '//   delay.ms 10;'
            ''
            '}_end_func ')
