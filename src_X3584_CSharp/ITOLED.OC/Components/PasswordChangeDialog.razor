@* PasswordChangeDialog.razor — Replaces Delphi TfrmChangePassword (PwdChange.pas) *@

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsSupervisor ? "Supervisor Change Password" : "Change Password")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_currentPassword" Label="Current Password"
                      InputType="InputType.Password" Variant="Variant.Outlined"
                      Margin="Margin.Dense" AutoFocus="true" />
        <MudTextField @bind-Value="_newPassword" Label="New Password"
                      InputType="InputType.Password" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="mt-2" />
        <MudTextField @bind-Value="_confirmPassword" Label="Confirm Password"
                      InputType="InputType.Password" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="mt-2"
                      OnKeyDown="OnKeyDown" />
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1">@_errorMessage</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="OnCancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OnOk">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Inject] private IConfigurationService ConfigService { get; set; } = default!;
    [Parameter] public bool IsSupervisor { get; set; }

    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    private string _errorMessage = "";

    private void OnOk()
    {
        var storedPw = IsSupervisor
            ? ConfigService.SystemInfo?.SupervisorPassword ?? ""
            : ConfigService.SystemInfo?.Password ?? "";

        if (_currentPassword != storedPw)
        {
            _errorMessage = "Current Password is not matched!";
            return;
        }

        if (string.IsNullOrEmpty(_newPassword))
        {
            _errorMessage = "New Password cannot be empty!";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _errorMessage = "Confirm Password is not matched to New password!";
            return;
        }

        // Save new password
        var sysInfo = ConfigService.SystemInfo!;
        if (IsSupervisor)
            sysInfo.SupervisorPassword = _newPassword;
        else
            sysInfo.Password = _newPassword;
        ConfigService.SaveSystemInfo();

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void OnCancel() => MudDialog.Cancel();

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") OnOk();
        else if (e.Key == "Escape") OnCancel();
    }
}
