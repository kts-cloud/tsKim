@* NgMessageDialog.razor — Replaces Delphi TfrmNgMsg (NGMsg.pas) *@
@* Simple NG message display dialog *@

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Color="Color.Error">NG Notification</MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Error" Dense="true">@Message</MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OnClose">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Message { get; set; } = "";

    private void OnClose() => MudDialog.Close(DialogResult.Ok(true));
}
