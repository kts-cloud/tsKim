@* WaitOverlay.razor — Replaces Delphi TfrmWaitCa210 (WaitMsg.pas) *@
@* Simple overlay component with progress indicator *@

@if (IsVisible)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999">
        <MudPaper Class="pa-6 d-flex flex-column align-center" Elevation="4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4">@Message</MudText>
        </MudPaper>
    </MudOverlay>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Message { get; set; } = "Please wait...";
}
