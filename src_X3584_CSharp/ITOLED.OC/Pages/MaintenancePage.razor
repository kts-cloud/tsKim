@page "/maintenance"
@implements IDisposable
@using System.IO
@inject IJSRuntime JS
@* MaintenancePage — replaces Mainter.pas/Mainter.dfm *@
@* Maintenance operations: PG communication, DIO test, manual device control *@

<PageTitle>Maintenance</PageTitle>

@if (!_isAuthenticated)
{
    <MudPaper Class="pa-6 d-flex flex-column align-center justify-center" Style="min-height: 300px;">
        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Warning" Class="mb-3" />
        <MudText Typo="Typo.h6" Class="mb-3">Admin Login Required</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnAdminLoginClick">Login</MudButton>
    </MudPaper>
}
else
{

<MudText Typo="Typo.h5" Class="mb-3">Maintenance</MudText>

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
    @* ── PG Communication Tab (Delphi: Mainter.pas PG/CAM tab) ── *@
    <MudTabPanel Text="PG Comm" Icon="@Icons.Material.Filled.Cable">
        <MudGrid Spacing="2">
            @* ── Left: Status + Command ── *@
            <MudItem xs="6">
                @* PG Channel Selector (Delphi: cboChannelPg) *@
                <MudSelect T="int" Label="PG Channel" Value="_selectedPgCh"
                           ValueChanged="OnPgChannelChanged"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2">
                    <MudSelectItem T="int" Value="0">CH 1</MudSelectItem>
                    <MudSelectItem T="int" Value="1">CH 2</MudSelectItem>
                    <MudSelectItem T="int" Value="2">CH 3</MudSelectItem>
                    <MudSelectItem T="int" Value="3">CH 4</MudSelectItem>
                </MudSelect>

                @* PG Status *@
                <MudPaper Class="pa-3 mb-2">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">PG Status (DP860) — CH @(_selectedPgCh + 1)</MudText>
                    <MudGrid Spacing="1">
                        <MudItem xs="4">
                            <MudText Typo="Typo.body2">Status:</MudText>
                            <MudChip T="string" Color="@GetPgStatusColor()" Size="Size.Small">@_pgStatusText</MudChip>
                        </MudItem>
                        <MudItem xs="4">
                            <MudText Typo="Typo.body2">IP:</MudText>
                            <MudText Typo="Typo.caption" Style="font-family: monospace;">@_pgIpAddress</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudText Typo="Typo.body2">Version:</MudText>
                            <MudText Typo="Typo.caption" Style="font-family: monospace;">@_pgVersion</MudText>
                        </MudItem>
                    </MudGrid>
                    @if (PgDriver.IsPowerOn)
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.body2" Class="mb-1">Power Data (mV)</MudText>
                        <MudText Typo="Typo.caption" Style="font-family: monospace;">
                            VCC=@(PgDriver.PowerData.Vcc)
                            VIN=@(PgDriver.PowerData.Vin)
                            VDD3=@(PgDriver.PowerData.Vdd3)
                        </MudText>
                    }
                </MudPaper>

                @* Command Input *@
                <MudPaper Class="pa-3">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">PG Command</MudText>
                    <MudSelect T="int" Label="Command" @bind-Value="_selectedPgCmd"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        @for (int i = 0; i < _pgCmdLabels.Length; i++)
                        {
                            var idx = i;
                            <MudSelectItem T="int" Value="idx">@_pgCmdLabels[idx]</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTextField T="string" @bind-Value="_pgParam" Label="Parameter" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Class="mt-2" Placeholder="@GetParamHint()"
                                  HelperText="@GetParamHint()" />
                    <div class="d-flex gap-2 mt-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="OnSendPgCmd" Disabled="@(_pgCmdBusy || _seqRunning)">
                            @if (_pgCmdBusy)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                            }
                            Send
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="OnClearLog">
                            Clear Log
                        </MudButton>
                    </div>
                </MudPaper>
            </MudItem>

            @* ── Right: TX/RX Log ── *@
            <MudItem xs="6">
                <MudPaper Class="pa-3" Style="height: 480px; display: flex; flex-direction: column;">
                    @{
                        LogEntry[] logSnapshot;
                        lock (_pgLogLock) { logSnapshot = _pgLog.ToArray(); }
                    }
                    <MudText Typo="Typo.subtitle1" Class="mb-2">TX/RX Log (@logSnapshot.Length)</MudText>
                    <div id="pgLogPanel" style="flex: 1; overflow-y: auto; background: #1a1a1a; padding: 4px 8px; border-radius: 4px;">
                        @foreach (var entry in logSnapshot)
                        {
                            <div style="@GetLogLineStyle(entry.Direction); font-family: 'Consolas', monospace; font-size: 0.75rem; line-height: 1.5; border-bottom: 1px solid #2a2a2a; padding: 1px 0;">
                                <span style="color: #757575;">@entry.Time</span>
                                <span style="@GetLogDirectionStyle(entry.Direction); font-weight: 600; margin: 0 4px;">@entry.Direction</span>
                                <span>@entry.Message</span>
                            </div>
                        }
                        @if (logSnapshot.Length == 0)
                        {
                            <div style="color: #616161; font-family: monospace; font-size: 0.75rem; padding: 8px;">(no log)</div>
                        }
                    </div>
                </MudPaper>
            </MudItem>

            @* ── Test Sequence Panel ── *@
            <MudItem xs="12">
                <MudExpansionPanels MultiExpansion="true">
                    <MudExpansionPanel Text="Test Sequence" Icon="@Icons.Material.Filled.PlaylistPlay">
                        <MudGrid Spacing="2">
                            @* File management + Test Count *@
                            <MudItem xs="12">
                                <div class="d-flex align-center gap-2">
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.FolderOpen"
                                               OnClick="OnSeqLoad" Disabled="_seqRunning">Load</MudButton>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Save"
                                               OnClick="OnSeqSave" Disabled="_seqRunning">Save</MudButton>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.SaveAs"
                                               OnClick="OnSeqSaveAs" Disabled="_seqRunning">Save As</MudButton>
                                    @if (!string.IsNullOrEmpty(_seqFilePath))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@_seqFilePath</MudChip>
                                    }
                                    <MudSpacer />
                                    <MudNumericField T="int" @bind-Value="_seqTestCount" Label="Test Count"
                                                     Min="1" Max="9999" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     Style="max-width: 120px;" Disabled="_seqRunning" />
                                </div>
                            </MudItem>

                            @* Command text area *@
                            <MudItem xs="12">
                                <MudTextField T="string" @bind-Value="_seqText" Label="Commands (one per line, // for comments)"
                                              Variant="Variant.Outlined" Lines="8" ReadOnly="_seqRunning"
                                              Style="font-family: 'Consolas', monospace; font-size: 0.85rem;" />
                            </MudItem>

                            @* Progress *@
                            @if (_seqRunning)
                            {
                                <MudItem xs="12">
                                    <MudProgressLinear Color="Color.Primary" Striped="true" Size="Size.Medium"
                                                       Value="@SeqProgressPercent" />
                                    <MudText Typo="Typo.caption" Style="font-family: monospace;" Class="mt-1">@_seqProgressText</MudText>
                                </MudItem>
                            }

                            @* Start / Stop *@
                            <MudItem xs="12">
                                <div class="d-flex gap-2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.PlayArrow"
                                               OnClick="OnSeqStart" Disabled="@(_seqRunning || _pgCmdBusy)">
                                        Test Start
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Stop"
                                               OnClick="OnSeqStop" Disabled="@(!_seqRunning)">
                                        Test Stop
                                    </MudButton>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ── DIO Test Tab ──────────────────────────────── *@
    <MudTabPanel Text="DIO Test" Icon="@Icons.Material.Filled.SettingsInputComponent">
        <MudGrid Spacing="2">
            <MudItem xs="6">
                <MudPaper Class="pa-3">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">DIO Output</MudText>
                    @for (int bit = 0; bit < 16; bit++)
                    {
                        var b = bit;
                        <MudCheckBox T="bool" Label="@($"OUT {b:D2}")"
                                     Value="@_dioOutput[b]" ValueChanged="@(v => OnDioOutputChanged(b, v))"
                                     Dense="true" />
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Class="pa-3">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">DIO Input (Read-Only)</MudText>
                    @for (int bit = 0; bit < 16; bit++)
                    {
                        var b = bit;
                        <MudCheckBox T="bool" Label="@($"IN {b:D2}")" Value="@_dioInput[b]"
                                     ReadOnly="true" Dense="true" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ── FTP Test Tab ─────────────────────── *@
    <MudTabPanel Text="FTP Test" Icon="@Icons.Material.Filled.CloudUpload">
        @* Row 1: Connection Bar *@
        <MudPaper Class="pa-2 mb-2">
            <div class="d-flex align-center gap-3 flex-wrap">
                <MudSelect T="int" Label="Channel" Value="_ftpSelectedCh" ValueChanged="OnFtpChannelChanged"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 100px;">
                    <MudSelectItem T="int" Value="0">CH 1</MudSelectItem>
                    <MudSelectItem T="int" Value="1">CH 2</MudSelectItem>
                    <MudSelectItem T="int" Value="2">CH 3</MudSelectItem>
                    <MudSelectItem T="int" Value="3">CH 4</MudSelectItem>
                </MudSelect>
                <MudChip T="string" Size="Size.Small"
                         Color="@(_ftpUseDpdk ? Color.Success : Color.Info)" Variant="Variant.Filled">
                    @(_ftpUseDpdk ? "DPDK lwIP" : "Socket")
                </MudChip>
                <MudText Typo="Typo.body2" Style="font-family: monospace;">
                    @(PgDrivers[_ftpSelectedCh].PgIpAddress):21
                </MudText>
                <MudIcon Icon="@(_ftpConnected ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                         Color="@(_ftpConnected ? Color.Success : Color.Default)" Size="Size.Small" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           OnClick="OnFtpConnect" Disabled="@(_ftpConnected || _ftpBusy)">
                    @if (_ftpBusy && !_ftpConnected) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                    Connect
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                           OnClick="OnFtpDisconnect" Disabled="@(!_ftpConnected || _ftpBusy)">
                    Disconnect
                </MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="OnFtpRefreshList" Disabled="@(!_ftpConnected || _ftpTransferring)"
                           StartIcon="@Icons.Material.Filled.Refresh">
                    Refresh
                </MudButton>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="OnFtpClearLog">Clear Log</MudButton>
            </div>
        </MudPaper>

        @* Row 2: File List + Log *@
        <MudGrid Spacing="2">
            <MudItem xs="7">
                <MudPaper Class="pa-3" Style="height: 340px; display: flex; flex-direction: column;">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Remote Files (/home/upload)</MudText>
                    @if (!_ftpConnected)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="my-2">Connect to PG to browse files</MudAlert>
                    }
                    else if (_ftpFiles.Count == 0)
                    {
                        <MudAlert Severity="Severity.Normal" Dense="true" Class="my-2">No files (or LIST pending)</MudAlert>
                    }
                    <div style="flex: 1; overflow-y: auto;">
                        <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="font-size: 0.8rem;">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th style="width:80px;">Size</th>
                                    <th style="width:110px;">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var filesSnapshot = _ftpFiles.ToArray(); }
                                @foreach (var f in filesSnapshot)
                                {
                                    var isSelected = _ftpSelectedFileEntry == f;
                                    <tr @onclick="() => OnFileRowClicked(f)"
                                        style="cursor: pointer; @(isSelected ? "background: rgba(25,118,210,0.2);" : "")">
                                        <td>
                                            <MudIcon Icon="@(f.IsDirectory ? Icons.Material.Filled.Folder : Icons.Material.Filled.InsertDriveFile)"
                                                     Size="Size.Small" Class="mr-1"
                                                     Color="@(f.IsDirectory ? Color.Warning : Color.Default)" />
                                            @f.Name
                                        </td>
                                        <td>@(f.IsDirectory ? "-" : FormatFileSize(f.Size))</td>
                                        <td>@f.Date</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="5">
                <MudPaper Class="pa-3" Style="height: 340px; display: flex; flex-direction: column;">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">FTP Log</MudText>
                    <div id="ftpLogPanel" style="flex: 1; overflow-y: auto; background: #1a1a1a; padding: 4px 8px; border-radius: 4px;">
                        @{ string[] logSnapshot; lock (_ftpLogLock) { logSnapshot = _ftpLog.ToArray(); } }
                        @foreach (var line in logSnapshot)
                        {
                            <div style="font-family: 'Consolas', monospace; font-size: 0.72rem; line-height: 1.4; color: @GetFtpLogColor(line); border-bottom: 1px solid #2a2a2a; padding: 1px 0;">
                                @line
                            </div>
                        }
                        @if (logSnapshot.Length == 0)
                        {
                            <div style="color: #616161; font-family: monospace; font-size: 0.72rem; padding: 8px;">(no log)</div>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Row 3: Download / Upload / Delete *@
        <MudPaper Class="pa-3 mt-2">
            <MudGrid Spacing="2">
                @* Download section *@
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Download from PG</MudText>
                    <div class="d-flex align-center gap-2 mb-1">
                        <MudTextField T="string" @bind-Value="_ftpDownloadFilename" Label="Remote Filename"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Placeholder="Select from list or type filename" Style="flex: 1;" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="OnFtpDownloadFile"
                                   Disabled="@(!_ftpConnected || _ftpTransferring || string.IsNullOrWhiteSpace(_ftpDownloadFilename))">
                            @if (_ftpTransferring) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                            Download
                        </MudButton>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <MudTextField T="string" @bind-Value="_ftpSavePath" Label="Save to"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex: 1;" />
                    </div>
                </MudItem>
                @* Upload section *@
                <MudItem xs="4">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Upload to PG</MudText>
                    <div class="d-flex align-center gap-2">
                        <MudFileUpload T="IBrowserFile" FilesChanged="OnUploadFileSelected" Accept="*/*">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.AttachFile">
                                    @(_ftpUploadFile?.Name ?? "Choose File")
                                </MudButton>
                            </ActivatorContent>
                        </MudFileUpload>
                        @if (_ftpUploadFile != null)
                        {
                            <MudText Typo="Typo.caption">@FormatFileSize(_ftpUploadFile.Size)</MudText>
                        }
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="OnFtpUploadFile"
                                   Disabled="@(!_ftpConnected || _ftpTransferring || _ftpUploadFile == null)">
                            Upload
                        </MudButton>
                    </div>
                </MudItem>
                @* Delete section *@
                <MudItem xs="2">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Delete</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               OnClick="OnFtpDeleteFile"
                               Disabled="@(!_ftpConnected || _ftpTransferring || string.IsNullOrWhiteSpace(_ftpDownloadFilename))"
                               StartIcon="@Icons.Material.Filled.Delete">
                        Delete
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudTabPanel>
</MudTabs>

} @* end else _isAuthenticated *@

@code {
    // =========================================================================
    // DI Injection
    // =========================================================================
    [Inject] private ICommPgDriver[] PgDrivers { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private IConfigurationService ConfigSvc { get; set; } = default!;

    private bool _isAuthenticated;

    private async Task OnAdminLoginClick()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<LoginDialog>("Admin Login", options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
            _isAuthenticated = true;
    }

    // ── Channel selection for PG comm (Delphi: cboChannelPg) ──
    private int _selectedPgCh;
    private ICommPgDriver PgDriver => PgDrivers[_selectedPgCh];

    // =========================================================================
    // PG Command definitions (Delphi: Mainter.pas MAINT_PG_CMD_xxx)
    // =========================================================================
    private const int PgCmdPowerOn      = 0;
    private const int PgCmdPowerOff     = 1;
    private const int PgCmdBistOn       = 2;
    private const int PgCmdBistOff      = 3;
    private const int PgCmdPatternNum   = 4;
    private const int PgCmdPatternNext  = 5;
    private const int PgCmdPatternRgb   = 6;
    private const int PgCmdBistRgb      = 7;
    private const int PgCmdTconRead     = 8;
    private const int PgCmdTconWrite    = 9;
    private const int PgCmdFlashAllRead = 10;
    private const int PgCmdDp860Raw     = 11;

    // Delphi: cmbxPgCmd.Items (DP860 only, AF9 excluded)
    private static readonly string[] _pgCmdLabels =
    [
        "Power ON",                            // 0
        "Power Off",                           // 1
        "Power BIST ON",                       // 2
        "Power BIST Off",                      // 3
        "Pattern (param: index)",              // 4
        "Pattern NEXT",                        // 5
        "Pattern RGB (param: R G B)",          // 6
        "Pattern BIST RGB (param: R G B)",     // 7
        "TCon Reg Read (param: addr count)",   // 8
        "TCon Reg Write (param: addr data..)", // 9
        "Flash ALL Read",                      // 10
        "DP860 PG Command (param: raw cmd)",   // 11
    ];

    // Win32 wait result constants (Delphi: WAIT_OBJECT_0 / WAIT_TIMEOUT / WAIT_FAILED)
    private const uint WaitObject0  = 0x00000000;
    private const uint WaitTimeout  = 0x00000102;
    private const uint WaitFailed   = 0xFFFFFFFF;

    // =========================================================================
    // PG State
    // =========================================================================
    private int _selectedPgCmd;
    private string _pgParam = "";
    private bool _pgCmdBusy;
    private readonly List<LogEntry> _pgLog = [];
    private readonly object _pgLogLock = new();

    private string _pgStatusText = "---";
    private string _pgIpAddress = "---";
    private string _pgVersion = "---";

    private System.Threading.Timer? _pgStatusTimer;

    // =========================================================================
    // Test Sequence State
    // =========================================================================
    private string _seqText = "";
    private int _seqTestCount = 1;
    private bool _seqRunning;
    private CancellationTokenSource? _seqCts;
    private int _seqCurrentLine;
    private int _seqTotalLines;
    private int _seqCurrentRound;
    private string _seqFilePath = "";
    private string _seqProgressText = "";
    private double SeqProgressPercent => _seqTotalLines > 0
        ? (double)((_seqCurrentRound - 1) * _seqTotalLines + _seqCurrentLine) / (_seqTestCount * _seqTotalLines) * 100
        : 0;

    // =========================================================================
    // DIO State
    // =========================================================================
    private readonly bool[] _dioOutput = new bool[16];
    private readonly bool[] _dioInput = new bool[16];

    // =========================================================================
    // Lifecycle
    // =========================================================================

    protected override void OnInitialized()
    {
        // Enable maintenance event logging on initial channel (Delphi: FIsMainter := True)
        SubscribePgEvents();

        // 1-second timer to refresh PG status display
        _pgStatusTimer = new System.Threading.Timer(_ =>
        {
            RefreshPgStatus();
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    public void Dispose()
    {
        _seqCts?.Cancel();
        _seqCts?.Dispose();
        _pgStatusTimer?.Dispose();
        UnsubscribePgEvents();
        DisposeFtpResources();
    }

    private void SubscribePgEvents()
    {
        PgDriver.IsMainter = true;
        PgDriver.TxMaintEventPg += OnPgTx;
        PgDriver.RxMaintEventPg += OnPgRx;
    }

    private void UnsubscribePgEvents()
    {
        PgDriver.TxMaintEventPg -= OnPgTx;
        PgDriver.RxMaintEventPg -= OnPgRx;
        PgDriver.IsMainter = false;
    }

    private void OnPgChannelChanged(int newCh)
    {
        if (newCh == _selectedPgCh) return;
        UnsubscribePgEvents();
        _selectedPgCh = newCh;
        SubscribePgEvents();
        _pgLog.Clear();
        RefreshPgStatus();
        StateHasChanged();
    }

    // =========================================================================
    // PG Status Refresh
    // =========================================================================

    private void RefreshPgStatus()
    {
        _pgStatusText = PgDriver.Status switch
        {
            PgStatus.Disconnected => "Disconnected",
            PgStatus.Connected    => "Connected",
            PgStatus.GetPgVersion => "GetVersion",
            _                     => PgDriver.IsPgReady ? "Ready" : PgDriver.Status.ToString()
        };

        _pgIpAddress = PgDriver.PgIpAddress;

        var ver = PgDriver.Version;
        _pgVersion = !string.IsNullOrEmpty(ver.FW)
            ? $"FW:{ver.FW} HW:{ver.HW}"
            : "---";
    }

    private Color GetPgStatusColor() => PgDriver.Status switch
    {
        PgStatus.Disconnected => Color.Error,
        PgStatus.Connected    => Color.Warning,
        _ => PgDriver.IsPgReady ? Color.Success : Color.Info
    };

    // =========================================================================
    // TX/RX Event Handlers (Delphi: DisplayPgLog)
    // =========================================================================

    private void OnPgTx(int pgIdx, string localPort, string remotePort, string cmd)
        => AddLog("TX", $"[{localPort}>{remotePort}] {cmd}");

    private void OnPgRx(int pgIdx, string localPort, string remotePort, string resp)
        => AddLog("RX", $"[{localPort}<{remotePort}] {resp}");

    private void AddLog(string message) => AddLog("--", message);

    private void AddLog(string direction, string message)
    {
        lock (_pgLogLock)
        {
            _pgLog.Add(new LogEntry(DateTime.Now.ToString("HH:mm:ss.fff"), direction, message));
            if (_pgLog.Count > 1000) _pgLog.RemoveAt(0);
        }
        InvokeAsync(async () =>
        {
            StateHasChanged();
            await Task.Yield();
            try { await JS.InvokeVoidAsync("eval", "document.getElementById('pgLogPanel')?.scrollTo(0, 999999)"); } catch { }
        });
    }

