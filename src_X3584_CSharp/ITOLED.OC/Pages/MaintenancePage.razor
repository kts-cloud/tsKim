    private void OnFtpChannelChanged(int newCh)
    {
        if (newCh == _ftpSelectedCh) return;
        if (_ftpConnected) { _ = OnFtpDisconnect(); return; }
        _ftpSelectedCh = newCh;
    }

    private readonly object _ftpLogLock = new();

    private void FtpLog(string msg)
    {
        lock (_ftpLogLock)
        {
            _ftpLog.Add($"{DateTime.Now:HH:mm:ss.fff} {msg}");
            if (_ftpLog.Count > 200) _ftpLog.RemoveAt(0);
        }
        InvokeAsync(async () =>
