    private async Task OnSendPgCmd()
    {
        _pgCmdBusy = true;
        StateHasChanged();

        try
        {
            PgDriver.SetCyclicTimer(false);
            await Task.Run(() => ExecutePgCommand(_selectedPgCmd, _pgParam.Trim()));
        }
        catch (Exception ex)
        {
            AddLog($"ERROR: {ex.Message}");
        }
        finally
        {
            PgDriver.SetCyclicTimer(true);
            _pgCmdBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ExecutePgCommand(int cmdIndex, string param)
    {
        // Parse parameters: replace "0x" with "$" notation is not needed in C#;
        // just parse hex (0x prefix) or decimal directly.
        var paramParts = ParseParams(param);

        switch (cmdIndex)
        {
            case PgCmdPowerOn:
                AddLog("Power ON");
                PgDriver.SendPowerOn(PgCommandParam.PowerOn);
                break;

            case PgCmdPowerOff:
                AddLog("Power Off");
                PgDriver.SendPowerOn(PgCommandParam.PowerOff);
                break;

            case PgCmdBistOn:
                AddLog("Power BIST ON");
                PgDriver.SendPowerBistOn(PgCommandParam.PowerOn);
                break;

            case PgCmdBistOff:
                AddLog("Power BIST Off");
                PgDriver.SendPowerBistOn(PgCommandParam.PowerOff);
                break;

            case PgCmdPatternNum:
            {
                if (paramParts.Length != 1)
                {
                    AddLog("Pattern# ...Parameter Error (Need 1 Parameter)");
                    return;
                }
                var patNum = paramParts[0];
                AddLog($"Display Pattern# : PatNum({patNum})");
                var rtn = PgDriver.SendDisplayPatNum(patNum);
                LogResult("Pattern#", rtn);
                break;
            }

            case PgCmdPatternNext:
            {
                AddLog("Display NEXT#");
                var rtn = PgDriver.SendDisplayPatNext();
                LogResult("Pattern NEXT", rtn);
                break;
            }

            case PgCmdPatternRgb:
            {
                if (paramParts.Length != 3)
                {
                    AddLog("Pattern RGB ...Parameter Error (Need 3 Parameters: R G B)");
                    return;
                }
                AddLog($"Pattern RGB: R({paramParts[0]}) G({paramParts[1]}) B({paramParts[2]})");
                var rtn = PgDriver.SendDisplayPatRgb(paramParts[0], paramParts[1], paramParts[2]);
                LogResult("Pattern RGB", rtn);
                break;
            }

            case PgCmdBistRgb:
            {
                if (paramParts.Length != 3)
                {
                    AddLog("BIST RGB ...Parameter Error (Need 3 Parameters: R G B)");
                    return;
                }
                AddLog($"Pattern BIST RGB: R({paramParts[0]}) G({paramParts[1]}) B({paramParts[2]})");
                var rtn = PgDriver.SendDisplayPatBistRgb(paramParts[0], paramParts[1], paramParts[2]);
                LogResult("BIST RGB", rtn);
                break;
            }

            case PgCmdTconRead:
            {
                if (paramParts.Length != 2)
                {
                    AddLog("TCon Read ...Parameter Error (Need 2 Parameters: addr count)");
                    return;
                }
                var addr = paramParts[0];
                var count = paramParts[1];
                AddLog($"TCON REG READ Addr(0x{addr:X}) DataCnt({count})");

                if (!PgDriver.IsPgReady)
                {
                    AddLog("TCON READ ...NG (Check PG Status)");
                    return;
                }

                var readBuf = new byte[count];
                var rtn = PgDriver.SendI2CRead(PgDeviceAddr.TconRegDevice, addr, count, readBuf);
                if (rtn == WaitObject0)
                {
                    var hexStr = string.Join(" ", readBuf.Select(b => $"0x{b:X2}"));
                    AddLog($"TCON READ OK: [{hexStr}]");
                }
                else
                {
                    LogResult("TCON READ", rtn);
                }
                break;
            }

            case PgCmdTconWrite:
            {
                if (paramParts.Length < 2)
                {
                    AddLog("TCon Write ...Parameter Error (Need min 2 Parameters: addr data0 [data1..])");
                    return;
                }
                var addr = paramParts[0];
                var dataLen = paramParts.Length - 1;
                var writeData = new byte[dataLen];
                var dataStr = "";
                for (int j = 0; j < dataLen; j++)
                {
                    writeData[j] = (byte)paramParts[j + 1];
                    dataStr += $" 0x{writeData[j]:X2}";
                }
                AddLog($"TCON WRITE Addr(0x{addr:X}) Data({dataStr.TrimStart()})");

                if (!PgDriver.IsPgReady)
                {
                    AddLog("TCON WRITE ...NG (Check PG Status)");
                    return;
                }

                var rtn = PgDriver.SendI2CWrite(PgDeviceAddr.TconRegDevice, addr, dataLen, writeData);
                LogResult("TCON WRITE", rtn);
                break;
            }

            case PgCmdFlashAllRead:
            {
                AddLog("---------- Flash ALL Read");
                var dataLen = PgFlashConstants.MaxFlashPucDataSizeByte;
                var flashBuf = new byte[dataLen];
                var rtn = PgDriver.SendFlashRead(0, (uint)dataLen, flashBuf, 30000);
                var ok = rtn == WaitObject0;
                AddLog($"Flash ALL Read {(ok ? "OK" : "NG")}");
                break;
            }

            case PgCmdDp860Raw:
            {
                if (string.IsNullOrWhiteSpace(param))
                {
                    AddLog("DP860 Command ...Parameter Error (Need command string)");
                    return;
                }
                AddLog($"DP860 CMD: {param}");
                var rtn = PgDriver.Dp860SendCmd(param, PgCommandParam.CmdIdUnknown,
                    PgCommandParam.CmdStrUnknown, 600000, 0);
                LogResult("DP860 CMD", rtn);
                break;
            }

            default:
                AddLog($"Unknown command index: {cmdIndex}");
                break;
        }
    }

    /// <summary>
    /// Parse space-separated parameters, supporting 0x hex prefix and decimal.
    /// Delphi: ExtractStrings + StrToIntDef with '$' replacement for '0x'.
    /// </summary>
    private static int[] ParseParams(string param)
    {
        if (string.IsNullOrWhiteSpace(param)) return [];
        var parts = param.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var result = new int[parts.Length];
        for (int i = 0; i < parts.Length; i++)
        {
            var s = parts[i].Trim();
            if (s.StartsWith("0x", StringComparison.OrdinalIgnoreCase))
                int.TryParse(s[2..], System.Globalization.NumberStyles.HexNumber, null, out result[i]);
            else
                int.TryParse(s, out result[i]);
        }
        return result;
    }

    /// <summary>Log command result (Delphi: WAIT_OBJECT_0 / WAIT_TIMEOUT / WAIT_FAILED check)</summary>
    private void LogResult(string cmdName, uint rtn)
    {
        if (rtn == WaitObject0) return; // success — no extra log needed
        var suffix = rtn switch
        {
            WaitFailed  => "NG (Failed)",
            WaitTimeout => "NG (Timeout)",
            _           => $"NG (0x{rtn:X8})"
        };
        AddLog($"{cmdName} ...{suffix}");
    }

