    private static string GetFtpLogColor(string line)
    {
        if (line.Contains("ERROR") || line.Contains("FAIL")) return "#EF5350";
        if (line.Contains("OK") || line.Contains("SUCCESS") || line.Contains("Connected")) return "#66BB6A";
        if (line.Contains(">>>")) return "#4FC3F7";
        return "#BDBDBD";
    }

    private void OnFtpClearLog() => _ftpLog.Clear();

    // ─── Connect ───────────────────────────────────────

    private async Task OnFtpConnect()
    {
        if (_ftpConnected || _ftpBusy) return;
        _ftpBusy = true;
        StateHasChanged();

        var pgIp = PgDrivers[_ftpSelectedCh].PgIpAddress;
        var mode = _ftpUseDpdk ? "DPDK" : "Socket";
        var sw = System.Diagnostics.Stopwatch.StartNew();

        try
        {
            FtpLog($"[{mode}] Connecting to {pgIp}:21...");

            if (_ftpUseDpdk)
                await Task.Run(ConnectDpdk);
            else
                await Task.Run(() => ConnectSocket(pgIp));

            sw.Stop();
            _ftpConnected = true;
            FtpLog($"[{mode}] Connected — Elapsed: {sw.ElapsedMilliseconds}ms");

            // Auto LIST after connect
            await RefreshFileList();
        }
        catch (Exception ex)
        {
            sw.Stop();
            FtpLog($"[{mode}] ERROR: {ex.Message}");
            CleanupFtpState();
        }
        finally
        {
            _ftpBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ConnectSocket(string pgIp)
    {
        var tcp = new System.Net.Sockets.TcpClient();
        tcp.ReceiveTimeout = 5000;
        tcp.SendTimeout = 5000;

        var connectTask = tcp.ConnectAsync(pgIp, 21);
        if (!connectTask.Wait(5000))
        {
            tcp.Dispose();
            throw new TimeoutException("Connection timeout (5s)");
        }

        var stream = tcp.GetStream();
        var reader = new StreamReader(stream, System.Text.Encoding.ASCII);
        var writer = new StreamWriter(stream, System.Text.Encoding.ASCII) { AutoFlush = true };

        // 220 Welcome
        var welcome = ReadFtpLine(reader);
        FtpLog($"<<< {welcome}");
        if (!welcome.StartsWith("220")) throw new Exception($"Unexpected: {welcome}");

        // Login
        writer.WriteLine($"USER {Dongaeltek.ITOLED.Core.Definitions.Dp860Ftp.FtpUsername}");
        FtpLog($">>> USER {Dongaeltek.ITOLED.Core.Definitions.Dp860Ftp.FtpUsername}");
        var userResp = ReadFtpLine(reader);
        FtpLog($"<<< {userResp}");

        writer.WriteLine($"PASS {Dongaeltek.ITOLED.Core.Definitions.Dp860Ftp.FtpPassword}");
        FtpLog(">>> PASS ****");
        var passResp = ReadFtpLine(reader);
        FtpLog($"<<< {passResp}");
        if (!passResp.StartsWith("230")) throw new Exception($"Login failed: {passResp}");

        _ftpTcpClient = tcp;
        _ftpReader = reader;
        _ftpWriter = writer;
    }

    private void ConnectDpdk()
    {
        var nic = Program.NicCoordinator;
        if (nic == null) throw new InvalidOperationException("DPDK NicCoordinator not initialized");

        var lease = nic.AcquireFtpAccessAsync().GetAwaiter().GetResult();
        FtpLog("[DPDK] NIC lease acquired (PG RX paused)");

        var engine = new HwNet.Engine.HwFtpEngine(HwNet.HwManager.Instance);
        var pgIp = PgDrivers[_ftpSelectedCh].PgIpAddress;
        var ftpConfig = new HwNet.Config.FtpConfig
        {
            ServerIp = pgIp,
            ServerPort = 21,
            Username = Dongaeltek.ITOLED.Core.Definitions.Dp860Ftp.FtpUsername,
            Password = Dongaeltek.ITOLED.Core.Definitions.Dp860Ftp.FtpPassword,
            LocalIp = $"{Dongaeltek.ITOLED.Core.Definitions.Dp860Network.NetworkPrefix}.10",
            Netmask = "255.255.255.0",
            Gateway = $"{Dongaeltek.ITOLED.Core.Definitions.Dp860Network.NetworkPrefix}.10",
            TimeoutMs = 10000
        };

        if (!engine.InitLwip(ftpConfig))
        {
            lease.DisposeAsync().GetAwaiter().GetResult();
            throw new Exception($"lwIP init failed: {engine.LastError}");
        }
        FtpLog("[DPDK] lwIP initialized");

        if (!engine.ConnectAsync(pgIp, 21,
            Dongaeltek.ITOLED.Core.Definitions.Dp860Ftp.FtpUsername,
            Dongaeltek.ITOLED.Core.Definitions.Dp860Ftp.FtpPassword, 10000).GetAwaiter().GetResult())
        {
            engine.StopLwip();
            engine.Dispose();
            lease.DisposeAsync().GetAwaiter().GetResult();
            throw new Exception($"FTP connect failed: {engine.LastError}");
        }

        _ftpEngine = engine;
        _ftpConfig = ftpConfig;
        _ftpLease = lease;
    }

    // ─── Disconnect ────────────────────────────────────

    private async Task OnFtpDisconnect()
    {
        if (!_ftpConnected || _ftpBusy) return;
        _ftpBusy = true;
        StateHasChanged();

        try
        {
            await Task.Run(DisconnectFtp);
            FtpLog("Disconnected");
        }
        catch (Exception ex)
        {
            FtpLog($"Disconnect ERROR: {ex.Message}");
        }
        finally
        {
            CleanupFtpState();
            _ftpConnected = false;
            _ftpBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void DisconnectFtp()
    {
        if (_ftpUseDpdk)
        {
            _ftpEngine?.DisconnectAsync().GetAwaiter().GetResult();
            _ftpEngine?.StopLwip();
            _ftpEngine?.Dispose();
            _ftpLease?.DisposeAsync().GetAwaiter().GetResult();
            FtpLog("[DPDK] NIC lease released (PG RX resumed)");
        }
        else
        {
            try { _ftpWriter?.WriteLine("QUIT"); } catch { }
            FtpLog(">>> QUIT");
            _ftpTcpClient?.Close();
        }
    }

    private void CleanupFtpState()
    {
        _ftpEngine = null;
        _ftpConfig = null;
        _ftpLease = null;
        try { _ftpTcpClient?.Dispose(); } catch { }
        _ftpTcpClient = null;
        _ftpReader = null;
        _ftpWriter = null;
    }

    // ─── DPDK Reconnect ─────────────────────────────────

    private async Task<bool> TryReconnectAsync()
    {
        if (!_ftpUseDpdk || _ftpEngine == null || _ftpConfig == null) return false;

        FtpLog("[DPDK] Connection lost — attempting reconnect...");
        bool ok = await _ftpEngine.ReconnectAsync(_ftpConfig);
        if (ok)
        {
            FtpLog("[DPDK] Reconnect OK");
            return true;
        }
        else
        {
            FtpLog("[DPDK] Reconnect FAIL — please Disconnect and Connect again");
            _ftpConnected = false;
            await InvokeAsync(StateHasChanged);
            return false;
        }
    }

    // ─── File List (LIST) ──────────────────────────────

    private async Task OnFtpRefreshList()
    {
        if (!_ftpConnected || _ftpTransferring) return;
        await RefreshFileList();
    }

    private async Task RefreshFileList()
    {
        _ftpTransferring = true;
        StateHasChanged();
        var sw = System.Diagnostics.Stopwatch.StartNew();

        try
        {
            FtpLog("[LIST] Fetching directory listing...");
            var listing = await Task.Run(FetchFileList);
            sw.Stop();

            if (listing != null)
            {
                _ftpFiles = ParseFtpListing(listing);
                FtpLog($"[LIST] OK — {_ftpFiles.Count} entries — {sw.ElapsedMilliseconds}ms");
            }
            else
            {
                _ftpFiles.Clear();
                FtpLog($"[LIST] Failed — {sw.ElapsedMilliseconds}ms");
            }
        }
        catch (Exception ex)
        {
            sw.Stop();
            FtpLog($"[LIST] ERROR: {ex.Message}");
            _ftpFiles.Clear();
        }
        finally
        {
            _ftpTransferring = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string? FetchFileList()
    {
        if (_ftpUseDpdk)
        {
            var listing = _ftpEngine!.ListAsync(10000).GetAwaiter().GetResult();
            if (listing == null)
            {
                // Reconnect and retry
                if (TryReconnectAsync().GetAwaiter().GetResult())
                    listing = _ftpEngine!.ListAsync(10000).GetAwaiter().GetResult();
            }
            return listing;
        }
        else
        {
            _ftpWriter!.WriteLine("PASV");
            FtpLog(">>> PASV");
            var pasvResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {pasvResp}");
            var (host, port) = ParsePasvResponse(pasvResp);

            using var dataClient = new System.Net.Sockets.TcpClient();
            dataClient.Connect(host, port);

            _ftpWriter.WriteLine("LIST");
            FtpLog(">>> LIST");
            var listResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {listResp}");

            using var ds = dataClient.GetStream();
            using var sr = new StreamReader(ds, System.Text.Encoding.ASCII);
            var listing = sr.ReadToEnd();
            dataClient.Close();

            var doneResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {doneResp}");
            return listing;
        }
    }

    private List<FtpFileEntry> ParseFtpListing(string listing)
    {
        var entries = new List<FtpFileEntry>();
        var lines = listing.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
        foreach (var line in lines)
        {
            if (string.IsNullOrWhiteSpace(line)) continue;
            var parts = line.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length < 9) continue;
            try
            {
                bool isDir = parts[0].StartsWith('d');
                long size = long.TryParse(parts[4], out long s) ? s : 0;
                string date = $"{parts[5]} {parts[6]} {parts[7]}";
                string name = string.Join(' ', parts, 8, parts.Length - 8);
                if (name == "." || name == "..") continue;
                entries.Add(new FtpFileEntry(name, size, date, isDir));
            }
            catch { }
        }
        entries.Sort((a, b) =>
        {
            if (a.IsDirectory != b.IsDirectory) return a.IsDirectory ? -1 : 1;
            return string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase);
        });
        return entries;
    }

    private void OnFileRowClicked(FtpFileEntry entry)
    {
        _ftpSelectedFileEntry = entry;
        if (!entry.IsDirectory)
            _ftpDownloadFilename = entry.Name;
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    // ─── Download File ──────────────────────────────────

    private async Task OnFtpDownloadFile()
    {
        var filename = _ftpDownloadFilename?.Trim();
        if (string.IsNullOrEmpty(filename) || !_ftpConnected || _ftpTransferring) return;
        _ftpTransferring = true;
        StateHasChanged();

        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            FtpLog($"[Download] Downloading '{filename}'...");

            // Ensure save directory exists
            if (!Directory.Exists(_ftpSavePath))
                Directory.CreateDirectory(_ftpSavePath);

            var data = await Task.Run(() => DownloadFileData(filename));
            sw.Stop();

            if (data == null || data.Length == 0)
            {
                FtpLog($"[Download] FAIL — file not found or empty");
                return;
            }

            var localPath = Path.Combine(_ftpSavePath, filename);
            File.WriteAllBytes(localPath, data);
            FtpLog($"[Download] SUCCESS — '{filename}' ({FormatFileSize(data.Length)}) → {localPath} — {sw.ElapsedMilliseconds}ms");
        }
        catch (Exception ex)
        {
            sw.Stop();
            FtpLog($"[Download] ERROR: {ex.Message}");
        }
        finally
        {
            _ftpTransferring = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private byte[]? DownloadFileData(string filename)
    {
        if (_ftpUseDpdk)
        {
            var data = _ftpEngine!.DownloadAsync(filename, 30000).GetAwaiter().GetResult();
            if (data == null)
            {
                FtpLog($"[Download] Failed — attempting reconnect...");
                if (TryReconnectAsync().GetAwaiter().GetResult())
                {
                    FtpLog($"[Download] Retrying RETR {filename}...");
                    data = _ftpEngine!.DownloadAsync(filename, 30000).GetAwaiter().GetResult();
                }
            }
            return data;
        }
        else
        {
            _ftpWriter!.WriteLine("TYPE I");
            FtpLog(">>> TYPE I");
            var typeResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {typeResp}");

            _ftpWriter.WriteLine("PASV");
            FtpLog(">>> PASV");
            var pasvResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {pasvResp}");
            var (host, port) = ParsePasvResponse(pasvResp);

            using var dataClient = new System.Net.Sockets.TcpClient();
            dataClient.Connect(host, port);

            _ftpWriter.WriteLine($"RETR {filename}");
            FtpLog($">>> RETR {filename}");
            var retrResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {retrResp}");
            if (!retrResp.StartsWith("150") && !retrResp.StartsWith("125"))
                throw new Exception($"RETR failed: {retrResp}");

            using var ds = dataClient.GetStream();
            using var ms = new MemoryStream();
            ds.CopyTo(ms);
            dataClient.Close();

            var doneResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {doneResp}");
            return ms.ToArray();
        }
    }

    // ─── Upload File ────────────────────────────────────

    private void OnUploadFileSelected(Microsoft.AspNetCore.Components.Forms.IBrowserFile? file)
    {
        _ftpUploadFile = file;
        if (file != null)
            FtpLog($"[Upload] Selected: {file.Name} ({FormatFileSize(file.Size)})");
    }

    private async Task OnFtpUploadFile()
    {
        if (_ftpUploadFile == null || !_ftpConnected || _ftpTransferring) return;
        _ftpTransferring = true;
        StateHasChanged();

        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            var filename = _ftpUploadFile.Name;
            FtpLog($"[Upload] Reading '{filename}'...");

            using var stream = _ftpUploadFile.OpenReadStream(maxAllowedSize: 64 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var data = ms.ToArray();

            FtpLog($"[Upload] Uploading '{filename}' ({FormatFileSize(data.Length)})...");
            await Task.Run(() => UploadFileData(filename, data));
            sw.Stop();
            FtpLog($"[Upload] SUCCESS — '{filename}' ({FormatFileSize(data.Length)}) — {sw.ElapsedMilliseconds}ms");

            _ftpUploadFile = null;
            await RefreshFileList();
        }
        catch (Exception ex)
        {
            sw.Stop();
            FtpLog($"[Upload] ERROR: {ex.Message}");
        }
        finally
        {
            _ftpTransferring = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void UploadFileData(string filename, byte[] data)
    {
        if (_ftpUseDpdk)
        {
            if (!_ftpEngine!.UploadAsync(filename, data, 30000).GetAwaiter().GetResult())
            {
                FtpLog($"[Upload] Failed — attempting reconnect...");
                if (TryReconnectAsync().GetAwaiter().GetResult())
                {
                    FtpLog($"[Upload] Retrying STOR {filename}...");
                    if (!_ftpEngine!.UploadAsync(filename, data, 30000).GetAwaiter().GetResult())
                        throw new Exception($"Upload failed after reconnect: {_ftpEngine.LastError}");
                }
                else
                {
                    throw new Exception($"Upload failed: {_ftpEngine.LastError}");
                }
            }
        }
        else
        {
            _ftpWriter!.WriteLine("TYPE I");
            FtpLog(">>> TYPE I");
            var typeResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {typeResp}");

            _ftpWriter.WriteLine("PASV");
            FtpLog(">>> PASV");
            var pasvResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {pasvResp}");
            var (host, port) = ParsePasvResponse(pasvResp);

            using var dataClient = new System.Net.Sockets.TcpClient();
            dataClient.Connect(host, port);

            _ftpWriter.WriteLine($"STOR {filename}");
            FtpLog($">>> STOR {filename}");
            var storResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {storResp}");

            using var ds = dataClient.GetStream();
            ds.Write(data, 0, data.Length);
            dataClient.Close();

            var doneResp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {doneResp}");
        }
    }

    // ─── Delete File ────────────────────────────────────

    private async Task OnFtpDeleteFile()
    {
        var filename = _ftpDownloadFilename?.Trim();
        if (string.IsNullOrEmpty(filename) || !_ftpConnected || _ftpTransferring) return;
        _ftpTransferring = true;
        StateHasChanged();

        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            FtpLog($"[Delete] Deleting '{filename}'...");
            await Task.Run(() => DeleteRemoteFile(filename));
            sw.Stop();
            FtpLog($"[Delete] SUCCESS — '{filename}' — {sw.ElapsedMilliseconds}ms");
            _ftpDownloadFilename = "";
            _ftpSelectedFileEntry = null;
            await RefreshFileList();
        }
        catch (Exception ex)
        {
            sw.Stop();
            FtpLog($"[Delete] ERROR: {ex.Message}");
        }
        finally
        {
            _ftpTransferring = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void DeleteRemoteFile(string filename)
    {
        if (_ftpUseDpdk)
        {
            throw new NotSupportedException("DPDK FTP engine does not support DELE command");
        }
        else
        {
            _ftpWriter!.WriteLine($"DELE {filename}");
            FtpLog($">>> DELE {filename}");
            var resp = ReadFtpLine(_ftpReader!);
            FtpLog($"<<< {resp}");
            if (!resp.StartsWith("250"))
                throw new Exception($"Delete failed: {resp}");
        }
    }

    // ─── FTP Helpers ───────────────────────────────────

    private static string ReadFtpLine(StreamReader reader)
    {
        var line = reader.ReadLine();
        return line ?? throw new Exception("FTP connection closed");
    }

    private static (string host, int port) ParsePasvResponse(string response)
    {
        // Parse "227 Entering Passive Mode (h1,h2,h3,h4,p1,p2)"
        var start = response.IndexOf('(');
        var end = response.IndexOf(')');
        if (start < 0 || end < 0) throw new Exception($"Invalid PASV response: {response}");
        var parts = response[(start + 1)..end].Split(',');
        if (parts.Length != 6) throw new Exception($"Invalid PASV format: {response}");
        var host = $"{parts[0]}.{parts[1]}.{parts[2]}.{parts[3]}";
        var port = int.Parse(parts[4]) * 256 + int.Parse(parts[5]);
        return (host, port);
    }

    // ─── Dispose cleanup ───────────────────────────────

    private void DisposeFtpResources()
    {
        if (_ftpConnected)
        {
            try { DisconnectFtp(); } catch { }
            CleanupFtpState();
            _ftpConnected = false;
        }
        _ftpFiles.Clear();
        _ftpUploadFile = null;
    }
}
