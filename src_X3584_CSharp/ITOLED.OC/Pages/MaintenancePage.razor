    private static readonly string SeqFolderPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "SeqFiles");

    private async Task OnSeqStart()
    {
        if (_seqRunning) return;
        var lines = _seqText.Split('\n', StringSplitOptions.RemoveEmptyEntries)
                            .Select(l => l.Trim())
                            .Where(l => !string.IsNullOrEmpty(l) && !l.StartsWith("//"))
                            .ToArray();
        if (lines.Length == 0)
        {
            Snackbar.Add("No commands to execute", Severity.Warning);
            return;
        }

        _seqRunning = true;
        _seqCts = new CancellationTokenSource();
        _seqTotalLines = lines.Length;
        _seqCurrentLine = 0;
        _seqCurrentRound = 1;
        StateHasChanged();

        try
        {
            PgDriver.SetCyclicTimer(false);

            for (_seqCurrentRound = 1; _seqCurrentRound <= _seqTestCount; _seqCurrentRound++)
            {
                AddLog("SEQ", $"=== Round {_seqCurrentRound}/{_seqTestCount} START ===");

                for (_seqCurrentLine = 0; _seqCurrentLine < lines.Length; _seqCurrentLine++)
                {
                    _seqCts.Token.ThrowIfCancellationRequested();
                    var cmd = lines[_seqCurrentLine];
                    _seqProgressText = $"[{_seqCurrentLine + 1}/{lines.Length}] Round {_seqCurrentRound}/{_seqTestCount}: {cmd}";
                    await InvokeAsync(StateHasChanged);

                    AddLog("SEQ", $">>> {cmd}");
                    uint rtn = await Task.Run(() =>
                        PgDriver.Dp860SendCmd(cmd, PgCommandParam.CmdIdUnknown,
                            PgCommandParam.CmdStrUnknown, 600000, 0));
                    LogResult(cmd, rtn);

                    if (rtn != WaitObject0)
                    {
                        AddLog("SEQ", $"STOPPED: '{cmd}' failed");
                        return;
                    }
                }

                AddLog("SEQ", $"=== Round {_seqCurrentRound}/{_seqTestCount} COMPLETE ===");
            }

            AddLog("SEQ", $"All {_seqTestCount} round(s) complete");
            Snackbar.Add($"Test Sequence complete ({_seqTestCount} rounds)", Severity.Success);
        }
        catch (OperationCanceledException)
        {
            AddLog("SEQ", "Test stopped by user");
            Snackbar.Add("Test Sequence stopped", Severity.Warning);
        }
        catch (Exception ex)
        {
            AddLog("SEQ", $"ERROR: {ex.Message}");
        }
        finally
        {
            PgDriver.SetCyclicTimer(true);
            _seqRunning = false;
            _seqProgressText = "";
            _seqCts?.Dispose();
            _seqCts = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnSeqStop()
    {
        _seqCts?.Cancel();
    }

    private async Task OnSeqLoad()
    {
        try
        {
            Directory.CreateDirectory(SeqFolderPath);
            var files = Directory.GetFiles(SeqFolderPath, "*.seq")
                                 .Select(Path.GetFileName)
                                 .OrderBy(f => f)
                                 .ToArray();

            if (files.Length == 0)
            {
                Snackbar.Add("No .seq files found in SeqFiles/", Severity.Info);
                return;
            }

            // Show file selection dialog
            var parameters = new DialogParameters<SeqFileDialog>
            {
                { x => x.Files, files! }
            };
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
            var dialog = await DialogService.ShowAsync<SeqFileDialog>("Load Sequence", parameters, options);
            var result = await dialog.Result;

            if (result is not null && !result.Canceled && result.Data is string fileName)
            {
                var filePath = Path.Combine(SeqFolderPath, fileName);
                _seqText = await File.ReadAllTextAsync(filePath);
                _seqFilePath = fileName;
                Snackbar.Add($"Loaded: {fileName}", Severity.Success);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Load error: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnSeqSave()
    {
        if (string.IsNullOrEmpty(_seqFilePath))
        {
            await OnSeqSaveAs();
            return;
        }

        try
        {
            Directory.CreateDirectory(SeqFolderPath);
            await File.WriteAllTextAsync(Path.Combine(SeqFolderPath, _seqFilePath), _seqText);
            Snackbar.Add($"Saved: {_seqFilePath}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save error: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnSeqSaveAs()
    {
        try
        {
            var parameters = new DialogParameters<SeqFileNameDialog>
            {
                { x => x.CurrentName, _seqFilePath }
            };
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
            var dialog = await DialogService.ShowAsync<SeqFileNameDialog>("Save Sequence As", parameters, options);
            var result = await dialog.Result;

            if (result is not null && !result.Canceled && result.Data is string fileName)
            {
                if (!fileName.EndsWith(".seq", StringComparison.OrdinalIgnoreCase))
                    fileName += ".seq";

                Directory.CreateDirectory(SeqFolderPath);
                await File.WriteAllTextAsync(Path.Combine(SeqFolderPath, fileName), _seqText);
                _seqFilePath = fileName;
                Snackbar.Add($"Saved: {fileName}", Severity.Success);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save error: {ex.Message}", Severity.Error);
        }
    }

