    private void LoadFromConfig()
    {
        var sys = Config.SystemInfo;
        if (sys is null) return;

        // Tab 1: System
        _equipmentId = sys.EQPId ?? "";
        _modelName = sys.TestModel ?? "";
        _swVersion = sys.SWVerInterlock ?? "";
        _ocType = sys.OCType;
        _chCountUsed = sys.ChCountUsed;
        _dioType = sys.DIOType;
        _pgType = sys.PGType;
        _pgMemorySize = sys.PGMemorySize;
        _ngAlarmCount = sys.NGAlarmCount;
        _retryCount = sys.RetryCount;
        _ecsTimeout = sys.ECSTimeout;
        _autoStart = sys.AutoStart;
        _ocManualType = sys.OcManualType;
        _useITOMode = sys.UseITOMode;
        _chReversal = sys.CHReversal;
        _useECS = sys.UseECS;
        _useMES = sys.UseMES;
        _useGIB = sys.UseGIB;
        _powerLog = sys.PowerLog;
        _password = sys.Password ?? "";
        _supervisorPassword = sys.SupervisorPassword ?? "";
        _comIrTempSensor = sys.ComIrTempSensor;

        if (sys.ComHandBCR is not null)
            Array.Copy(sys.ComHandBCR, _comHandBCR, Math.Min(sys.ComHandBCR.Length, _comHandBCR.Length));
        if (sys.ComRCB is not null)
            Array.Copy(sys.ComRCB, _comRCB, Math.Min(sys.ComRCB.Length, _comRCB.Length));
        if (sys.ComIonizer is not null)
            Array.Copy(sys.ComIonizer, _comIonizer, Math.Min(sys.ComIonizer.Length, _comIonizer.Length));

        // Tab 2: PLC
        var plc = Config.PlcInfo;
        if (plc is not null)
        {
            _plcEqpId = plc.EQPId;
            _plcStationNo = plc.StationNo;
            _plcPollingInterval = plc.PollingInterval;
            _plcTimeoutConnection = plc.TimeoutConnection;
            _plcTimeoutECS = plc.TimeoutECS;
            _plcZone = plc.Zone;
            _plcAddrECS = plc.AddressECS ?? "";
            _plcAddrRobot = plc.AddressRobot ?? "";
            _plcAddrEQP = plc.AddressEQP ?? "";
            _plcAddrECSWrite = plc.AddressECSWrite ?? "";
            _plcAddrRobotWrite = plc.AddressRobotWrite ?? "";
            _plcAddrEQPWrite = plc.AddressEQPWrite ?? "";
            _plcAddrDoorOpen = plc.AddressDoorOpen ?? "";
            _plcUseSimulation = plc.UseSimulation;
            _plcInlineGIB = plc.InlineGIB;
        }

        // Tab 3: DFS / Paths
        var dfs = Config.DfsConfInfo;
        if (dfs is not null)
        {
            _dfsServerIp = dfs.DfsServerIP ?? "";
            _dfsUser = dfs.DfsUserName ?? "";
            _dfsPassword = dfs.DfsPassword ?? "";
            _dfsCombiDownPath = dfs.CombiDownPath ?? "";
            _dfsProcessName = dfs.ProcessName ?? "";
            _dfsUseDfs = dfs.UseDfs;
            _dfsHexCompress = dfs.DfsHexCompress;
            _dfsHexDelete = dfs.DfsHexDelete;
            _dfsUseCombiDown = dfs.UseCombiDown;
        }

        _rootPath = PathMgr?.RootDir ?? "";
        _logPath = PathMgr?.LogDir ?? "";
        _hostFTPIP = sys.HostFTPIPAddr ?? "";
        _hostFTPUser = sys.HostFTPUser ?? "";
        _hostFTPPasswd = sys.HostFTPPasswd ?? "";
        _hostFTPCombiPath = sys.HostFTPCombiPath ?? "";

        // Tab 4: GMES / EAS / R2R
        _mesServicePort = sys.ServicePort ?? "";
        _mesNetwork = sys.Network ?? "";
        _mesDaemonPort = sys.DaemonPort ?? "";
        _mesLocalSubject = sys.LocalSubject ?? "";
        _mesRemoteSubject = sys.RemoteSubject ?? "";
        _eqpIdType = sys.EQPIdType;
        _easService = sys.EasService ?? "";
        _easNetwork = sys.EasNetwork ?? "";
        _easDaemonPort = sys.EasDaemonPort ?? "";
        _easLocalSubject = sys.EasLocalSubject ?? "";
        _easRemoteSubject = sys.EasRemoteSubject ?? "";
        _r2rService = sys.R2RService ?? "";
        _r2rNetwork = sys.R2RNetwork ?? "";
        _r2rDaemonPort = sys.R2RDaemonPort ?? "";
        _r2rLocalSubject = sys.R2RLocalSubject ?? "";
        _r2rRemoteSubject = sys.R2RRemoteSubject ?? "";

        // Tab 5: CA410 / PG
        if (sys.ComCa310 is not null)
            Array.Copy(sys.ComCa310, _comCa310, Math.Min(sys.ComCa310.Length, _comCa310.Length));
        if (sys.ComCa310DeviceId is not null)
            Array.Copy(sys.ComCa310DeviceId, _comCa310DeviceId, Math.Min(sys.ComCa310DeviceId.Length, _comCa310DeviceId.Length));
        if (sys.ComCa310Serial is not null)
        {
            for (int i = 0; i < Math.Min(sys.ComCa310Serial.Length, _comCa310Serial.Length); i++)
                _comCa310Serial[i] = sys.ComCa310Serial[i] ?? "";
        }

        // Restore saved device list from INI (Delphi: Com_CaDeviceList)
        _ca410DeviceOptions.Clear();
        if (sys.ComCaDeviceList is not null)
        {
            foreach (var item in sys.ComCaDeviceList)
            {
                if (string.IsNullOrWhiteSpace(item)) break;
                _ca410DeviceOptions.Add(item);
            }
        }

        // Clamp selection indices to valid range (0=NONE, 1..N=devices)
        for (int i = 0; i < _comCa310.Length; i++)
        {
            if (_comCa310[i] > _ca410DeviceOptions.Count)
                _comCa310[i] = 0;
        }

        _pgTconWriteCmdType = sys.PGTconWriteCmdType;
        _pgTconReadCmdType = sys.PGTconReadCmdType;
        _pgTconOcWriteDelayMsec = sys.PGTconOcWriteDelayMsec;
        _pgWriteReadPassAddr = sys.PGWriteReadPassAddr ?? "";
        _pgTconReadBeforeDelayMsec = sys.PGTconReadBeforeDelayMsec;
        _pgWaitAckAfterContOcWriteCnt = sys.PGWaitAckAfterContOcWriteCnt;
        _pgTconWriteLogDisplay = sys.PGTconWriteLogDisplay;
        _pgGpioReadHpdBeforeMeasure = sys.PGGpioReadHpdBeforeMeasure;
        _debugLogLevel = sys.DebugLogLevelConfig;
    }

    private async Task SaveConfig()
