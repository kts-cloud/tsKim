@page "/system-setup"
@* SystemSetupPage — replaces SystemSetup.pas/SystemSetup.dfm *@
@* System configuration: PLC, DIO, PG, network, file paths *@

<PageTitle>System Setup</PageTitle>

@if (!_isAuthenticated)
{
    <MudPaper Class="pa-6 d-flex flex-column align-center justify-center" Style="min-height: 300px;">
        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Warning" Class="mb-3" />
        <MudText Typo="Typo.h6" Class="mb-3">Admin Login Required</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnAdminLoginClick">Login</MudButton>
    </MudPaper>
}
else
{

<MudText Typo="Typo.h5" Class="mb-3">System Setup</MudText>

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
    @* ══════════════════════════════════════════════════════════════════════════ *@
    @* Tab 1: System Config                                                      *@
    @* ══════════════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="System" Icon="@Icons.Material.Filled.Computer">
        <MudText Typo="Typo.subtitle1" Class="mb-2">General</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_equipmentId" Label="Equipment ID" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_modelName" Label="Test Model" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_swVersion" Label="SW Version" Variant="Variant.Outlined" ReadOnly="true" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_ocType" Label="OC Type" Variant="Variant.Outlined" Min="0" Max="3" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_chCountUsed" Label="CH Count Used" Variant="Variant.Outlined" Min="1" Max="4" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_dioType" Label="DIO Type" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_pgType" Label="PG Type" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_pgMemorySize" Label="PG Memory Size" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_ngAlarmCount" Label="NG Alarm Count" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_retryCount" Label="Retry Count" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_ecsTimeout" Label="ECS Timeout (ms)" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Feature Flags</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_autoStart" Label="Auto Start" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_ocManualType" Label="OC Manual Type" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_useITOMode" Label="ITO Mode" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_chReversal" Label="CH Reversal" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_useECS" Label="Use ECS" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_useMES" Label="Use MES" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_useGIB" Label="Use GIB" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_powerLog" Label="Power Log" /></MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Passwords</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="6">
                <MudTextField T="string" @bind-Value="_password" Label="Password" Variant="Variant.Outlined" InputType="InputType.Password" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField T="string" @bind-Value="_supervisorPassword" Label="Supervisor Password" Variant="Variant.Outlined" InputType="InputType.Password" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">COM Ports</MudText>
        <MudGrid Spacing="2">
            @for (int i = 0; i < _comHandBCR.Length; i++)
            {
                var idx = i;
                <MudItem xs="3">
                    <MudNumericField T="int" @bind-Value="_comHandBCR[idx]" Label="@($"HandBCR {idx+1}")" Variant="Variant.Outlined" />
                </MudItem>
            }
            @for (int i = 0; i < _comRCB.Length; i++)
            {
                var idx = i;
                <MudItem xs="3">
                    <MudNumericField T="int" @bind-Value="_comRCB[idx]" Label="@($"RCB {idx+1}")" Variant="Variant.Outlined" />
                </MudItem>
            }
            @for (int i = 0; i < _comIonizer.Length; i++)
            {
                var idx = i;
                <MudItem xs="3">
                    <MudNumericField T="int" @bind-Value="_comIonizer[idx]" Label="@($"Ionizer {idx+1}")" Variant="Variant.Outlined" />
                </MudItem>
            }
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_comIrTempSensor" Label="IR Temp Sensor" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ══════════════════════════════════════════════════════════════════════════ *@
    @* Tab 2: PLC / ECS Config                                                   *@
    @* ══════════════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="PLC / ECS" Icon="@Icons.Material.Filled.Memory">
        <MudText Typo="Typo.subtitle1" Class="mb-2">PLC Connection</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_plcEqpId" Label="EQP ID" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_plcStationNo" Label="Station No" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_plcPollingInterval" Label="Polling Interval (ms)" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_plcZone" Label="Zone" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Timeouts</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="6">
                <MudNumericField T="int" @bind-Value="_plcTimeoutConnection" Label="Connection Timeout (ms)" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudNumericField T="int" @bind-Value="_plcTimeoutECS" Label="ECS Timeout (ms)" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Addresses (Read)</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_plcAddrECS" Label="ECS Read" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_plcAddrRobot" Label="Robot Read" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_plcAddrEQP" Label="EQP Read" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Addresses (Write)</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_plcAddrECSWrite" Label="ECS Write" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_plcAddrRobotWrite" Label="Robot Write" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_plcAddrEQPWrite" Label="EQP Write" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Options</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4"><MudCheckBox T="bool" @bind-Value="_plcUseSimulation" Label="Use Simulation" /></MudItem>
            <MudItem xs="4"><MudCheckBox T="bool" @bind-Value="_plcInlineGIB" Label="Inline GIB" /></MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_plcAddrDoorOpen" Label="Door Open Address" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ══════════════════════════════════════════════════════════════════════════ *@
    @* Tab 3: DFS / Network / Paths                                              *@
    @* ══════════════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="DFS / Paths" Icon="@Icons.Material.Filled.Wifi">
        <MudText Typo="Typo.subtitle1" Class="mb-2">DFS Server</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_dfsServerIp" Label="DFS Server IP" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_dfsUser" Label="DFS User" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_dfsPassword" Label="DFS Password" Variant="Variant.Outlined" InputType="InputType.Password" />
            </MudItem>
            <MudItem xs="8">
                <MudTextField T="string" @bind-Value="_dfsCombiDownPath" Label="Combi Download Path" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_dfsProcessName" Label="Process Name" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">DFS Options</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_dfsUseDfs" Label="Use DFS" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_dfsHexCompress" Label="HEX Compress" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_dfsHexDelete" Label="HEX Delete" /></MudItem>
            <MudItem xs="3"><MudCheckBox T="bool" @bind-Value="_dfsUseCombiDown" Label="Use Combi DL" /></MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Paths</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudTextField T="string" @bind-Value="_rootPath" Label="Root Directory" Variant="Variant.Outlined" FullWidth="true" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField T="string" @bind-Value="_logPath" Label="Log Directory" Variant="Variant.Outlined" FullWidth="true" ReadOnly="true" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">FTP</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="3">
                <MudTextField T="string" @bind-Value="_hostFTPIP" Label="Host FTP IP" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudTextField T="string" @bind-Value="_hostFTPUser" Label="Host FTP User" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudTextField T="string" @bind-Value="_hostFTPPasswd" Label="Host FTP Password" Variant="Variant.Outlined" InputType="InputType.Password" />
            </MudItem>
            <MudItem xs="3">
                <MudTextField T="string" @bind-Value="_hostFTPCombiPath" Label="FTP Combi Path" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ══════════════════════════════════════════════════════════════════════════ *@
    @* Tab 4: GMES / EAS / R2R                                                   *@
    @* ══════════════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="GMES / EAS / R2R" Icon="@Icons.Material.Filled.Hub">
        <MudText Typo="Typo.subtitle1" Class="mb-2">GMES</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="3">
                <MudTextField T="string" @bind-Value="_mesServicePort" Label="Service Port" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudTextField T="string" @bind-Value="_mesNetwork" Label="Network" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudTextField T="string" @bind-Value="_mesDaemonPort" Label="Daemon Port" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="3">
                <MudNumericField T="int" @bind-Value="_eqpIdType" Label="EQP ID Type" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField T="string" @bind-Value="_mesLocalSubject" Label="Local Subject" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField T="string" @bind-Value="_mesRemoteSubject" Label="Remote Subject" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">EAS</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_easService" Label="Service" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_easNetwork" Label="Network" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_easDaemonPort" Label="Daemon Port" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField T="string" @bind-Value="_easLocalSubject" Label="Local Subject" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField T="string" @bind-Value="_easRemoteSubject" Label="Remote Subject" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">R2R</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_r2rService" Label="Service" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_r2rNetwork" Label="Network" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_r2rDaemonPort" Label="Daemon Port" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField T="string" @bind-Value="_r2rLocalSubject" Label="Local Subject" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField T="string" @bind-Value="_r2rRemoteSubject" Label="Remote Subject" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ══════════════════════════════════════════════════════════════════════════ *@
    @* Tab 5: CA410 / PG Settings                                                *@
    @* ══════════════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="CA410 / PG" Icon="@Icons.Material.Filled.Tune">
        <MudText Typo="Typo.subtitle1" Class="mb-2">CA310/CA410 (per Channel)</MudText>

        @* ── Scan Button (Delphi: RzBitBtn4Click) ── *@
        <div class="d-flex align-center gap-3 mb-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="ScanCa410"
                       StartIcon="@Icons.Material.Filled.Usb">
                Load CA-410 Devices
            </MudButton>
            <MudText Typo="Typo.caption" Style="color: #9E9E9E;">
                Detected: @_ca410DeviceOptions.Count device(s)
            </MudText>
        </div>

        @* ── Per-Channel Device Selection ── *@
        <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="max-width: 800px;">
            <thead>
                <tr>
                    <th>CH</th>
                    <th style="min-width: 300px;">Device</th>
                    <th>Device ID</th>
                    <th>Serial No</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < _comCa310.Length; i++)
                {
                    var idx = i;
                    <tr>
                        <td style="font-weight:600;">@(idx + 1)</td>
                        <td>
                            <MudSelect T="int" Value="_comCa310[idx]"
                                       ValueChanged="@(v => OnCa410DeviceSelected(idx, v))"
                                       Dense="true" Margin="Margin.Dense" Variant="Variant.Text">
                                <MudSelectItem T="int" Value="0">NONE</MudSelectItem>
                                @for (int d = 0; d < _ca410DeviceOptions.Count; d++)
                                {
                                    var capturedD = d;
                                    var devIdx = capturedD + 1;
                                    var devText = _ca410DeviceOptions[capturedD];
                                    <MudSelectItem T="int" Value="devIdx">@devText</MudSelectItem>
                                }
                            </MudSelect>
                        </td>
                        <td><MudText Typo="Typo.body2" Style="font-family: monospace;">@_comCa310DeviceId[idx]</MudText></td>
                        <td><MudText Typo="Typo.body2" Style="font-family: monospace;">@_comCa310Serial[idx]</MudText></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">PG TCON Settings</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudNumericField T="int" @bind-Value="_pgTconWriteCmdType" Label="TCON Write Cmd Type" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudNumericField T="int" @bind-Value="_pgTconReadCmdType" Label="TCON Read Cmd Type" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudNumericField T="int" @bind-Value="_pgTconOcWriteDelayMsec" Label="OC Write Delay (ms)" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudTextField T="string" @bind-Value="_pgWriteReadPassAddr" Label="WriteRead Pass Addr" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudNumericField T="int" @bind-Value="_pgTconReadBeforeDelayMsec" Label="Read Before Delay (ms)" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudNumericField T="int" @bind-Value="_pgWaitAckAfterContOcWriteCnt" Label="Wait Ack Cnt" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="4">
                <MudCheckBox T="bool" @bind-Value="_pgTconWriteLogDisplay" Label="TCON Write Log Display" />
            </MudItem>
            <MudItem xs="4">
                <MudCheckBox T="bool" @bind-Value="_pgGpioReadHpdBeforeMeasure" Label="GPIO Read HPD" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Debug</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudNumericField T="int" @bind-Value="_debugLogLevel" Label="Debug Log Level" Variant="Variant.Outlined" Min="0" Max="5" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    @* ══════════════════════════════════════════════════════════════════════════ *@
    @* Tab 6: OC Factory Config (Delphi: tbOcFactoryConfig in SystemSetup)       *@
    @* ══════════════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="OC Factory Config" Icon="@Icons.Material.Filled.Extension">
        <MudText Typo="Typo.subtitle1" Class="mb-2">OC Factory Configuration (JSON)</MudText>

        @* ── Config Grid ── *@
        <MudSimpleTable Dense="true" Hover="true" Striped="true" Class="oc-factory-table" Style="max-width: 900px;">
            <thead>
                <tr>
                    <th style="width:60px;">Id</th>
                    <th>DllPath</th>
                    <th style="width:120px;">SubscriberType</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < _ocFactoryConfigs.Count; i++)
                {
                    var idx = i;
                    var cfg = _ocFactoryConfigs[idx];
                    var rowClass = _ocSelectedRow == idx ? "oc-row-selected" : "oc-row-clickable";
                    <tr class="@rowClass" @onclick="() => OnOcConfigRowClick(idx)">
                        <td>@cfg.Id</td>
                        <td style="font-family:monospace; font-size:0.85em;">@cfg.DllPath</td>
                        <td>@cfg.SubscriberType</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        @* ── Edit Fields ── *@
        <MudGrid Spacing="2" Class="mt-3" Style="max-width: 900px;">
            <MudItem xs="7">
                <MudTextField T="string" @bind-Value="_ocDllPath" Label="DllPath"
                              Variant="Variant.Outlined" Placeholder="LGDDLL\..." />
            </MudItem>
            <MudItem xs="2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.FolderOpen"
                           OnClick="BrowseOcDllFile"
                           Style="height: 56px;">Browse</MudButton>
            </MudItem>
            <MudItem xs="3">
                <MudSelect T="int" @bind-Value="_ocSubscriberType" Label="SubscriberType"
                           Variant="Variant.Outlined">
                    <MudSelectItem T="int" Value="1">1</MudSelectItem>
                    <MudSelectItem T="int" Value="2">2</MudSelectItem>
                    <MudSelectItem T="int" Value="3">3</MudSelectItem>
                    <MudSelectItem T="int" Value="4">4 (MLP)</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>

        @* ── Action Buttons ── *@
        <div class="d-flex gap-2 mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="AddOcConfig" StartIcon="@Icons.Material.Filled.Add">Add</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Info" Size="Size.Small"
                       OnClick="UpdateOcConfig" StartIcon="@Icons.Material.Filled.Edit">Update</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                       OnClick="DeleteOcConfig" StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                       OnClick="SaveOcFactoryConfig" StartIcon="@Icons.Material.Filled.Save">Save JSON</MudButton>
        </div>
    </MudTabPanel>
</MudTabs>

<MudPaper Class="pa-3 mt-3 d-flex gap-2">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveConfig">Save</MudButton>
