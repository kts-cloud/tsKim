        var sys = Config.SystemInfo;
        if (sys is null) return;

        // Tab 1: System
        sys.EQPId = _equipmentId;
        sys.TestModel = _modelName;
        sys.OCType = _ocType;
        sys.ChCountUsed = _chCountUsed;
        sys.DIOType = _dioType;
        sys.PGType = _pgType;
        sys.PGMemorySize = _pgMemorySize;
        sys.NGAlarmCount = _ngAlarmCount;
        sys.RetryCount = _retryCount;
        sys.ECSTimeout = _ecsTimeout;
        sys.AutoStart = _autoStart;
        sys.OcManualType = _ocManualType;
        sys.UseITOMode = _useITOMode;
        sys.CHReversal = _chReversal;
        sys.UseECS = _useECS;
        sys.UseMES = _useMES;
        sys.UseGIB = _useGIB;
        sys.PowerLog = _powerLog;
        sys.Password = _password;
        sys.SupervisorPassword = _supervisorPassword;
        sys.ComIrTempSensor = _comIrTempSensor;
        Array.Copy(_comHandBCR, sys.ComHandBCR, Math.Min(_comHandBCR.Length, sys.ComHandBCR.Length));
        Array.Copy(_comRCB, sys.ComRCB, Math.Min(_comRCB.Length, sys.ComRCB.Length));
        Array.Copy(_comIonizer, sys.ComIonizer, Math.Min(_comIonizer.Length, sys.ComIonizer.Length));

        // Tab 2: PLC
        var plc = Config.PlcInfo;
        if (plc is not null)
        {
            plc.EQPId = _plcEqpId;
            plc.StationNo = _plcStationNo;
            plc.PollingInterval = _plcPollingInterval;
            plc.TimeoutConnection = _plcTimeoutConnection;
            plc.TimeoutECS = _plcTimeoutECS;
            plc.Zone = _plcZone;
            plc.AddressECS = _plcAddrECS;
            plc.AddressRobot = _plcAddrRobot;
            plc.AddressEQP = _plcAddrEQP;
            plc.AddressECSWrite = _plcAddrECSWrite;
            plc.AddressRobotWrite = _plcAddrRobotWrite;
            plc.AddressEQPWrite = _plcAddrEQPWrite;
            plc.AddressDoorOpen = _plcAddrDoorOpen;
            plc.UseSimulation = _plcUseSimulation;
            plc.InlineGIB = _plcInlineGIB;
        }

        // Tab 3: DFS
        var dfs = Config.DfsConfInfo;
        if (dfs is not null)
        {
            dfs.DfsServerIP = _dfsServerIp;
            dfs.DfsUserName = _dfsUser;
            dfs.DfsPassword = _dfsPassword;
            dfs.CombiDownPath = _dfsCombiDownPath;
            dfs.ProcessName = _dfsProcessName;
            dfs.UseDfs = _dfsUseDfs;
            dfs.DfsHexCompress = _dfsHexCompress;
            dfs.DfsHexDelete = _dfsHexDelete;
            dfs.UseCombiDown = _dfsUseCombiDown;
        }

        sys.HostFTPIPAddr = _hostFTPIP;
        sys.HostFTPUser = _hostFTPUser;
        sys.HostFTPPasswd = _hostFTPPasswd;
        sys.HostFTPCombiPath = _hostFTPCombiPath;

        // Tab 4: GMES / EAS / R2R
        sys.ServicePort = _mesServicePort;
        sys.Network = _mesNetwork;
        sys.DaemonPort = _mesDaemonPort;
        sys.LocalSubject = _mesLocalSubject;
        sys.RemoteSubject = _mesRemoteSubject;
        sys.EQPIdType = _eqpIdType;
        sys.EasService = _easService;
        sys.EasNetwork = _easNetwork;
        sys.EasDaemonPort = _easDaemonPort;
        sys.EasLocalSubject = _easLocalSubject;
        sys.EasRemoteSubject = _easRemoteSubject;
        sys.R2RService = _r2rService;
        sys.R2RNetwork = _r2rNetwork;
        sys.R2RDaemonPort = _r2rDaemonPort;
        sys.R2RLocalSubject = _r2rLocalSubject;
        sys.R2RRemoteSubject = _r2rRemoteSubject;

        // Tab 5: CA410 / PG
        Array.Copy(_comCa310, sys.ComCa310, Math.Min(_comCa310.Length, sys.ComCa310.Length));
        Array.Copy(_comCa310DeviceId, sys.ComCa310DeviceId, Math.Min(_comCa310DeviceId.Length, sys.ComCa310DeviceId.Length));
        for (int i = 0; i < Math.Min(_comCa310Serial.Length, sys.ComCa310Serial.Length); i++)
            sys.ComCa310Serial[i] = _comCa310Serial[i];

        // Save device list (Delphi: Com_CaDeviceList)
        if (sys.ComCaDeviceList is not null)
        {
            for (int i = 0; i < sys.ComCaDeviceList.Length; i++)
                sys.ComCaDeviceList[i] = i < _ca410DeviceOptions.Count ? _ca410DeviceOptions[i] : "";
        }

        sys.PGTconWriteCmdType = _pgTconWriteCmdType;
        sys.PGTconReadCmdType = _pgTconReadCmdType;
        sys.PGTconOcWriteDelayMsec = _pgTconOcWriteDelayMsec;
        sys.PGWriteReadPassAddr = _pgWriteReadPassAddr;
        sys.PGTconReadBeforeDelayMsec = _pgTconReadBeforeDelayMsec;
        sys.PGWaitAckAfterContOcWriteCnt = _pgWaitAckAfterContOcWriteCnt;
        sys.PGTconWriteLogDisplay = _pgTconWriteLogDisplay;
        sys.PGGpioReadHpdBeforeMeasure = _pgGpioReadHpdBeforeMeasure;
        sys.DebugLogLevelConfig = _debugLogLevel;

        // Tab 6: OC Factory Config — save JSON file
        // (Delphi: SystemSetup.pas SaveOcFactoryConfig called before Common.SaveSystemInfo)
        SaveOcFactoryConfig();

        Config.Save();
        Snackbar.Add("Configuration saved", Severity.Success);

        // Offer SW reinitialize after save (Delphi: m_bIsChanged → InitialAll)
        if (AppInit.CanInitialize)
        {
            var initResult = await DialogService.ShowMessageBox(
                "Apply Changes",
                "설정이 저장되었습니다. 프로그램을 초기화하여 변경사항을 적용하시겠습니까?",
                yesText: "초기화", cancelText: "나중에");

            if (initResult == true)
            {
                var success = await AppInit.InitializeAllAsync();
                Snackbar.Add(
                    success ? "SW 초기화 완료" : "초기화 실패",
                    success ? Severity.Success : Severity.Error);
                Nav.NavigateTo("/");
            }
            else
            {
                Snackbar.Add("SW 초기화 후 적용됩니다.", Severity.Info);
            }
        }
    }

    private Task ReloadConfig()
    {
        Config.Reload();
        LoadFromConfig();
        Snackbar.Add("Configuration reloaded", Severity.Info);
        return Task.CompletedTask;
    }

    // =========================================================================
    // CA-410 Scan & Device Selection (Delphi: RzBitBtn4Click + cboCa310_XClick)
    // =========================================================================

    /// <summary>
    /// Reads already-detected CA-410 devices and populates the dropdown options.
    /// Delphi: TfrmSystemSetup.RzBitBtn4Click — reads CaSdk2.DeviceCount (no re-scan).
    /// ManualConnect was already called at startup (Program.cs).
    /// </summary>
    private Task ScanCa410()
    {
        // Read from existing device list (populated by ManualConnect at startup)
        _ca410DeviceOptions.Clear();
        foreach (var dev in Ca410.Devices)
        {
            _ca410DeviceOptions.Add(string.Format(DefCaSdk.CA410_DISPLAY_ITEM, dev.DeviceId, dev.SerialNo));
        }

        // Reset channel selections to NONE so user can re-assign
        for (int i = 0; i < _comCa310.Length; i++)
        {
            _comCa310[i] = 0;
            _comCa310DeviceId[i] = 0;
            _comCa310Serial[i] = "";
        }

        Snackbar.Add($"CA-410: {Ca410.DeviceCount} device(s) detected", Severity.Success);
        StateHasChanged();
        return Task.CompletedTask;
    }

    /// <summary>
    /// Called when user selects a CA-410 device for a channel.
    /// Delphi: cboCa310_XClick — extracts DeviceId and SerialNo from display string.
    /// </summary>
    private void OnCa410DeviceSelected(int channel, int selectedValue)
    {
        _comCa310[channel] = selectedValue;

        if (selectedValue == 0 || selectedValue > _ca410DeviceOptions.Count)
        {
            // NONE selected
            _comCa310DeviceId[channel] = 0;
            _comCa310Serial[channel] = "";
        }
        else
        {
            // selectedValue is 1-based index into _ca410DeviceOptions
            var devIndex = selectedValue - 1;
            if (devIndex < Ca410.Devices.Count)
            {
                var dev = Ca410.Devices[devIndex];
                _comCa310DeviceId[channel] = dev.DeviceId;
                _comCa310Serial[channel] = dev.SerialNo;
            }
        }

        StateHasChanged();
    }

    // =========================================================================
    // OC Factory Config — Load / Save / CRUD
    // (Delphi: SystemSetup.pas LoadOcFactoryConfig / SaveOcFactoryConfig)
    // =========================================================================

    private void LoadOcFactoryConfig()
    {
        _ocFactoryConfigs.Clear();
        _ocSelectedRow = -1;
        var path = Path.Combine(PathMgr.IniDir, "OC_Factory_Config.json");
        if (!File.Exists(path)) return;

        try
        {
            var json = File.ReadAllText(path, System.Text.Encoding.UTF8);
            var items = System.Text.Json.JsonSerializer.Deserialize<List<OcFactoryConfigItem>>(json);
            if (items != null)
                _ocFactoryConfigs = items;
        }
        catch
        {
            // ignore parse errors — grid stays empty
        }
    }

    private void SaveOcFactoryConfig()
    {
        // Sync ClassName from SubscriberType + normalize DllPath separators before saving
        // (Delphi: SaveOcFactoryConfig → GetClassNameByType)
        foreach (var cfg in _ocFactoryConfigs)
        {
            cfg.ClassName = GetClassNameByType(cfg.SubscriberType);
            cfg.DllPath = cfg.DllPath.Replace('/', '\\');
        }

        var path = Path.Combine(PathMgr.IniDir, "OC_Factory_Config.json");
        var options = new System.Text.Json.JsonSerializerOptions { WriteIndented = false };
        var json = System.Text.Json.JsonSerializer.Serialize(_ocFactoryConfigs, options);
        File.WriteAllText(path, json, System.Text.Encoding.UTF8);
        Snackbar.Add("OC Factory Config JSON saved", Severity.Success);
    }

    private static string GetClassNameByType(int type) => type switch
    {
        1 => "LGD_OC_X3584.OCFlow.CompensationFlow",
        2 => "LGD_OC_X3584_2.OCFlow.CompensationFlow",
        3 => "LGD_OC_X3584_5.OCFlow.CompensationFlow",
        4 => "LGD_OC_X3584.OCFlow.CompensationFlow",
        _ => "LGD_OC_X3584.OCFlow.CompensationFlow"
    };

    private void OnOcConfigRowClick(int rowIndex)
    {
        _ocSelectedRow = rowIndex;
        if (rowIndex >= 0 && rowIndex < _ocFactoryConfigs.Count)
        {
            _ocDllPath = _ocFactoryConfigs[rowIndex].DllPath;
            _ocSubscriberType = _ocFactoryConfigs[rowIndex].SubscriberType;
        }
    }

    private void AddOcConfig()
    {
        if (string.IsNullOrWhiteSpace(_ocDllPath))
        {
            Snackbar.Add("DllPath is empty", Severity.Warning);
            return;
        }
        var maxId = _ocFactoryConfigs.Count > 0 ? _ocFactoryConfigs.Max(c => c.Id) : -1;
        _ocFactoryConfigs.Add(new OcFactoryConfigItem
        {
            Id = maxId + 1,
            DllPath = _ocDllPath,
            ClassName = GetClassNameByType(_ocSubscriberType),
            SubscriberType = _ocSubscriberType
        });
    }

    private void UpdateOcConfig()
    {
        if (_ocSelectedRow < 0 || _ocSelectedRow >= _ocFactoryConfigs.Count) return;
        if (string.IsNullOrWhiteSpace(_ocDllPath))
        {
            Snackbar.Add("DllPath is empty", Severity.Warning);
            return;
        }
        _ocFactoryConfigs[_ocSelectedRow].DllPath = _ocDllPath;
        _ocFactoryConfigs[_ocSelectedRow].SubscriberType = _ocSubscriberType;
        _ocFactoryConfigs[_ocSelectedRow].ClassName = GetClassNameByType(_ocSubscriberType);
    }

    private void DeleteOcConfig()
    {
        if (_ocSelectedRow < 0 || _ocSelectedRow >= _ocFactoryConfigs.Count) return;
        _ocFactoryConfigs.RemoveAt(_ocSelectedRow);
        _ocSelectedRow = -1;
        _ocDllPath = "";
        _ocSubscriberType = 1;
    }

    /// <summary>
    /// Opens a Windows file dialog to pick an LGD Factory DLL.
    /// If the chosen file lives under the LGDDLL directory, stores it as a
    /// relative path (e.g., "LGDDLL\foo.dll"); otherwise stores the absolute path.
    /// </summary>
    private void BrowseOcDllFile()
    {
        // BlazorWebView runs on the WinForms UI thread (STA) — safe to invoke
        // OpenFileDialog directly. Wrap in try/catch so a dialog failure never
        // breaks the page.
        try
        {
            var lgdDllDir = PathMgr.LgdDllDir;
            using var ofd = new System.Windows.Forms.OpenFileDialog
            {
                Title = "Select LGD Factory DLL",
                Filter = "DLL files (*.dll)|*.dll|All files (*.*)|*.*",
                Multiselect = false,
                CheckFileExists = true,
                InitialDirectory = Directory.Exists(lgdDllDir)
                    ? lgdDllDir
                    : Environment.CurrentDirectory,
            };

            if (ofd.ShowDialog() != System.Windows.Forms.DialogResult.OK)
                return;

            var picked = Path.GetFullPath(ofd.FileName);

            // Try to convert to a path relative to the LGDDLL parent directory
            // so the JSON stays portable (e.g., "LGDDLL\LGD_OC_X3584_..._.dll").
            // LgdDllDir = "<root>\LGDDLL", so the relative root is its parent.
            string display = picked;
            if (Directory.Exists(lgdDllDir))
            {
                var relRoot = Path.GetFullPath(Path.Combine(lgdDllDir, ".."));
                if (picked.StartsWith(relRoot, StringComparison.OrdinalIgnoreCase))
                {
                    display = picked.Substring(relRoot.Length).TrimStart('\\', '/');
                }
            }

            _ocDllPath = display.Replace('/', '\\');
            Snackbar.Add($"Selected: {Path.GetFileName(picked)}", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Browse failed: {ex.Message}", Severity.Error);
        }
    }
}
