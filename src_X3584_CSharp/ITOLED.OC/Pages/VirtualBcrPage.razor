@page "/virtual-bcr"
@* VirtualBcrPage — 4-channel barcode input simulator *@
@* Replaces Delphi TfrmVirtualBcr (VirtualBcrForm.pas) *@
@* Sends ScriptGuiMessage via IMessageBus instead of WM_COPYDATA *@

@using Dongaeltek.ITOLED.Core.Interfaces
@using Dongaeltek.ITOLED.Core.Messaging
@using Dongaeltek.ITOLED.BusinessLogic.Scripting

<PageTitle>Virtual BCR</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Virtual BCR Simulator</MudText>

<MudGrid>
    @for (int i = 0; i < 4; i++)
    {
        var ch = i;
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-2">CH @(ch + 1)</MudText>
                <MudTextField @bind-Value="_barcodes[ch]" Label="Barcode"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudTextField @bind-Value="_ngCodes[ch]" Label="NG Code" T="int"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" />
                <div class="d-flex gap-2 mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="() => SendBcr(ch)">BCR Send</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                               OnClick="() => SendMesOk(ch)">MES OK</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                               OnClick="() => SendMesNg(ch)">MES NG</MudButton>
                </div>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

@code {
    [Inject] private IMessageBus MessageBus { get; set; } = default!;

    private readonly string[] _barcodes = ["", "", "", ""];
    private readonly int[] _ngCodes = new int[4];

    private void SendBcr(int ch)
    {
        if (string.IsNullOrWhiteSpace(_barcodes[ch])) return;
        MessageBus.Publish(new ScriptGuiMessage
        {
            Channel = ch,
            Mode = MessageConstants.MsgModeShowSerialNumber,
            Msg = _barcodes[ch].Trim()
        });
    }

    private void SendMesOk(int ch)
    {
        MessageBus.Publish(new ScriptGuiMessage
        {
            Channel = ch,
            Mode = MessageConstants.MsgModeChResult,
            Param = 0 // PASS
        });
    }

    private void SendMesNg(int ch)
    {
        MessageBus.Publish(new ScriptGuiMessage
        {
            Channel = ch,
            Mode = MessageConstants.MsgModeChResult,
            Param = _ngCodes[ch] > 0 ? _ngCodes[ch] : 1
        });
    }
}
